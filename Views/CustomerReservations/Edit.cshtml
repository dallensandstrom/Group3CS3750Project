@model Reservation

@{
    ViewData["Title"] = "Edit Reservation";
}

<h1>Edit Reservation</h1>

<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="ReservationID" />

            <div class="form-group">
                <label asp-for="SiteId" class="control-label"></label>
                <select asp-for="SiteId" class="form-control" asp-items="ViewBag.SiteId"></select>
                <span asp-validation-for="SiteId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="CheckInDate" class="control-label"></label>
                <input asp-for="CheckInDate" class="form-control" />
                <span asp-validation-for="CheckInDate" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="CheckOutDate" class="control-label"></label>
                <input asp-for="CheckOutDate" class="form-control" />
                <span asp-validation-for="CheckOutDate" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="NumAdults" class="control-label"></label>
                <input asp-for="NumAdults" class="form-control" />
                <span asp-validation-for="NumAdults" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Pets" class="control-label"></label>
                <input asp-for="Pets" class="form-control" />
                <span asp-validation-for="Pets" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="BaseCost" class="control-label"></label>
                <input asp-for="BaseCost" class="form-control" readonly />
            </div>
            <div class="form-group">
                <label asp-for="TotalCost" class="control-label"></label>
                <input asp-for="TotalCost" class="form-control" readonly />
            </div>
            <div class="form-group">
                <label asp-for="ExtraNotes" class="control-label"></label>
                <input asp-for="ExtraNotes" class="form-control" />
                <span asp-validation-for="ExtraNotes" class="text-danger"></span>
            </div>

            <div class="form-group mt-3">
                <input type="submit" value="Save" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        async function updateReservationPrice() {
            const siteId = document.getElementById("SiteId")?.value;
            const checkInDate = document.getElementById("CheckInDate")?.value;
            const checkOutDate = document.getElementById("CheckOutDate")?.value;
            const pets = document.getElementById("Pets")?.value || 0;

            const baseCostInput = document.getElementById("BaseCost");
            const totalCostInput = document.getElementById("TotalCost");

            if (!siteId || !checkInDate || !checkOutDate) {
                if (baseCostInput) baseCostInput.value = "";
                if (totalCostInput) totalCostInput.value = "";
                return;
            }

            try {
                const response = await fetch(`/CustomerReservations/GetReservationPrice?siteId=${siteId}&checkInDate=${checkInDate}&checkOutDate=${checkOutDate}&pets=${pets}`);
                const data = await response.json();

                if (data.success) {
                    if (baseCostInput) baseCostInput.value = Number(data.baseCost).toFixed(2);
                    if (totalCostInput) totalCostInput.value = Number(data.totalCost).toFixed(2);
                } else {
                    if (baseCostInput) baseCostInput.value = "";
                    if (totalCostInput) totalCostInput.value = "";
                }
            } catch {
                if (baseCostInput) baseCostInput.value = "";
                if (totalCostInput) totalCostInput.value = "";
            }
        }

        document.getElementById("SiteId")?.addEventListener("change", updateReservationPrice);
        document.getElementById("CheckInDate")?.addEventListener("change", updateReservationPrice);
        document.getElementById("CheckOutDate")?.addEventListener("change", updateReservationPrice);
        document.getElementById("Pets")?.addEventListener("input", updateReservationPrice);
        window.addEventListener("load", updateReservationPrice);
    </script>
}