@model Reservation

@{
    ViewData["Title"] = "Create Reservation";
}

<h1>Create Reservation</h1>

<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <input type="hidden" name="returnTo" value="@ViewBag.ReturnTo" />
            <input type="hidden" name="siteCategoryId" value="@ViewBag.ReturnSiteCategoryId" />
            <input type="hidden" name="minVehicleSize" value="@ViewBag.ReturnMinVehicleSize" />
            <input type="hidden" name="checkInDate" value="@ViewBag.ReturnCheckInDate" />
            <input type="hidden" name="checkOutDate" value="@ViewBag.ReturnCheckOutDate" />

            <div class="form-group">
                <label asp-for="SiteId" class="control-label"></label>
                <select asp-for="SiteId" class="form-control" asp-items="ViewBag.SiteId"></select>
                <span asp-validation-for="SiteId" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="CheckInDate" class="form-label"></label>
                <input asp-for="CheckInDate"           type="date"           id="checkInDate"           min="@DateTime.Today.ToString("yyyy-MM-dd")"
                       class="form-control" />
                <span asp-validation-for="CheckInDate" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="CheckOutDate" class="form-label"></label>
                <input asp-for="CheckOutDate"           type="date"           id="checkOutDate"           min="@DateTime.Today.ToString("yyyy-MM-dd")"
                       class="form-control" />
                <span asp-validation-for="CheckOutDate" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="NumAdults" class="control-label"></label>
                <input asp-for="NumAdults" class="form-control" />
                <span asp-validation-for="NumAdults" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Pets" class="control-label"></label>
                <input asp-for="Pets" class="form-control" />
                <span asp-validation-for="Pets" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="BaseCost" class="control-label"></label>
                <input asp-for="BaseCost" class="form-control" readonly />
            </div>
            <div class="form-group">
                <label asp-for="TotalCost" class="control-label"></label>
                <input asp-for="TotalCost" class="form-control" readonly />
            </div>
            <div class="form-group">
                <label asp-for="ExtraNotes" class="control-label"></label>
                <input asp-for="ExtraNotes" class="form-control" />
                <span asp-validation-for="ExtraNotes" class="text-danger"></span>
            </div>

            <div class="form-group mt-3">
                <input type="submit" value="Create" class="btn btn-primary" />
                @if ((string)ViewBag.ReturnTo == "catalog")
                {
                    <a asp-controller="Site" asp-action="Index" asp-route-siteCategoryId="@ViewBag.ReturnSiteCategoryId"
                           asp-route-minVehicleSize="@ViewBag.ReturnMinVehicleSize"
                           asp-route-checkInDate="@ViewBag.ReturnCheckInDate"
                           asp-route-checkOutDate="@ViewBag.ReturnCheckOutDate" class="btn btn-secondary">
                        Back
                    </a>
                }
                else
                {
                    <a asp-action="Index" class="btn btn-secondary">Back</a>
                }
            </div>
        </form>
    </div>
</div>

<script>
    async function updateReservationPrice() {
        const siteId = document.getElementById("SiteId")?.value;
        const checkInDate = document.getElementById("CheckInDate")?.value;
        const checkOutDate = document.getElementById("CheckOutDate")?.value;
        const pets = document.getElementById("Pets")?.value || 0;

        const baseCostInput = document.getElementById("BaseCost");
        const totalCostInput = document.getElementById("TotalCost");

        if (!siteId || !checkInDate || !checkOutDate) {
            if (baseCostInput) baseCostInput.value = "";
            if (totalCostInput) totalCostInput.value = "";
            return;
        }

        try {
            const response = await fetch(`/CustomerReservations/GetReservationPrice?siteId=${siteId}&checkInDate=${checkInDate}&checkOutDate=${checkOutDate}&pets=${pets}`);
            const data = await response.json();

            if (data.success) {
                if (baseCostInput) baseCostInput.value = Number(data.baseCost).toFixed(2);
                if (totalCostInput) totalCostInput.value = Number(data.totalCost).toFixed(2);
            } else {
                if (baseCostInput) baseCostInput.value = "";
                if (totalCostInput) totalCostInput.value = "";
            }
        } catch {
            if (baseCostInput) baseCostInput.value = "";
            if (totalCostInput) totalCostInput.value = "";
        }
    }

    document.addEventListener("DOMContentLoaded", function () {
        const checkIn = document.getElementById("CheckInDate");
        const checkOut = document.getElementById("CheckOutDate");
        const siteId = document.getElementById("SiteId");
        const pets = document.getElementById("Pets");
        const today = "@DateTime.Today.ToString("yyyy-MM-dd")";

        if (!checkIn || !checkOut) return;

        function addOneDay(dateString) {
            const d = new Date(dateString + "T00:00:00");
            d.setDate(d.getDate() + 1);
            return d.toISOString().split("T")[0];
        }

        function updateDateLimits() {
            if (checkIn.value) {
                checkOut.min = addOneDay(checkIn.value);
            } else {
                checkOut.min = addOneDay(today);
            }
        }

        function fixInvalidCheckout() {
            if (!checkIn.value) return;

            const minimumCheckout = addOneDay(checkIn.value);

            if (!checkOut.value || checkOut.value <= checkIn.value) {
                checkOut.value = minimumCheckout;
            }
        }

        checkIn.addEventListener("change", function () {
            updateDateLimits();
            fixInvalidCheckout();
            updateReservationPrice();
        });

        checkOut.addEventListener("change", function () {
            if (checkIn.value && checkOut.value <= checkIn.value) {
                checkOut.value = addOneDay(checkIn.value);
            }

            updateReservationPrice();
        });

        siteId?.addEventListener("change", updateReservationPrice);
        pets?.addEventListener("input", updateReservationPrice);

        updateDateLimits();
        fixInvalidCheckout();
        updateReservationPrice();
    });
</script>
}