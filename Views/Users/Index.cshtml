@model IEnumerable<GroupThreeTrailerParkProject.Models.UserAccountViewModel>

@{
    ViewData["Title"] = "View Employee Accounts";
}

<div class="container mt-4">
    <h1>@ViewData["Title"]</h1>

    @if (!Model.Any())
    {
        <div class="alert alert-info mt-3">
            No employee or admin accounts found.
        </div>
    }
    else
    {
        <table class="table table-striped table-hover mt-3">
            <thead class="table-dark">
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Role(s)</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr id="user-row-@user.Id">
                        <td>@user.FirstName @user.LastName</td>
                        <td>@user.Email</td>
                        <td>@user.Roles</td>
                        <td>
                            <span class="badge @(user.IsEnabled ? "bg-success" : "bg-danger")" id="status-@user.Id">
                                @(user.IsEnabled ? "Enabled" : "Disabled")
                            </span>
                        </td>
                        <td>
                            <button class="btn btn-sm @(user.IsEnabled ? "btn-warning" : "btn-success") toggle-user-btn"
                                    data-user-id="@user.Id"
                                    data-current-status="@user.IsEnabled.ToString().ToLower()">
                                @(user.IsEnabled ? "Disable" : "Enable")
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('.toggle-user-btn').on('click', function () {
                var button = $(this);
                var userId = button.data('user-id');
                var currentStatus = button.data('current-status') === 'true';

                // Disable button during request
                button.prop('disabled', true);

                $.ajax({
                    url: '@Url.Action("ToggleUserStatus", "Users")',
                    type: 'POST',
                    data: {
                        userId: userId,
                        __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function (result) {
                        if (result.success) {
                            // Update status badge
                            var statusBadge = $('#status-' + userId);
                            if (result.isEnabled) {
                                statusBadge.removeClass('bg-danger').addClass('bg-success').text('Enabled');
                                button.removeClass('btn-success').addClass('btn-warning').text('Disable');
                            } else {
                                statusBadge.removeClass('bg-success').addClass('bg-danger').text('Disabled');
                                button.removeClass('btn-warning').addClass('btn-success').text('Enable');
                            }
                            button.data('current-status', result.isEnabled);
                        } else {
                            alert('Failed to update user status: ' + result.message);
                        }
                    },
                    error: function () {
                        alert('An error occurred while updating user status.');
                    },
                    complete: function () {
                        button.prop('disabled', false);
                    }
                });
            });
        });
    </script>
}
