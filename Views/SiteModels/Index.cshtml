@model IEnumerable<GroupThreeTrailerParkProject.Models.SiteModel>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.SiteCategoryId)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.MaxVehicleSize)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.VisibleToClient)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.DefaultPrice)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.SiteCategoryId)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.MaxVehicleSize)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.VisibleToClient)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.DefaultPrice)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.SiteId">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.SiteId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.SiteId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
