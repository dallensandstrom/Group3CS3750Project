@model GroupThreeTrailerParkProject.Models.Site

@{
    ViewData["Title"] = "Site Details";
    var photos = ViewBag.Photos as List<GroupThreeTrailerParkProject.Models.SitePhoto>;
}

<div class="container mt-4">
    <h2 class="mb-4">Site @Model.SiteId</h2>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <h4 class="card-title mb-3">Site Information</h4>

            <p><strong>Category:</strong> @(Model.SiteCategory?.Name ?? "None")</p>
            <p><strong>Max Vehicle Size:</strong> @Model.MaxVehicleSize</p>
            <p><strong>Visible To Client:</strong> @(Model.VisibleToClient ? "Yes" : "No")</p>
        </div>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <h4 class="card-title mb-3">Pricing</h4>

            @if (Model.SiteCategory?.PriceRanges != null && Model.SiteCategory.PriceRanges.Any())
            {
                <div class="table-responsive">
                    <table class="table table-bordered align-middle">
                        <thead>
                            <tr>
                                <th>Price</th>
                                <th>Start Date</th>
                                <th>End Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var range in Model.SiteCategory.PriceRanges.OrderBy(p => p.StartDate))
                            {
                                <tr>
                                    <td>@range.Price.ToString("C")</td>
                                    <td>@range.StartDate.ToShortDateString()</td>
                                    <td>@(range.EndDate.HasValue ? range.EndDate.Value.ToShortDateString() : "No end date")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p>No pricing has been added for this category yet.</p>
            }
        </div>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <h4 class="card-title mb-3">Photos</h4>

            <div class="row">
                @if (photos != null && photos.Any())
                {
                    @foreach (var photo in photos)
                    {
                        <div class="col-md-3 mb-3">
                            <div class="card shadow-sm">
                                <img src="@photo.PhotoUrl"
                                     class="card-img-top"
                                     alt="Site Photo"
                                     style="height: 180px; object-fit: cover;" />
                            </div>
                        </div>
                    }
                }
                else
                {
                    <p>No photos available for this site.</p>
                }
            </div>
        </div>
    </div>

    <div class="d-flex gap-2">
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Edit" asp-route-id="@Model.SiteId" class="btn btn-primary">Edit</a>
    }

    @if (User.IsInRole("Guest"))
    {
        <a asp-controller="CustomerReservations"
           asp-action="Create"
           asp-route-siteId="@Model.SiteId"
           class="btn btn-success">
            Reserve
        </a>
    }

    <a asp-action="Index" class="btn btn-secondary">Back</a>
</div>
</div>