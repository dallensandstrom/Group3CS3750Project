@model GroupThreeTrailerParkProject.Models.Site

@{
    ViewData["Title"] = "Delete Site";
}

<h2>Delete Site</h2>

<h3>Are you sure you want to delete this site?</h3>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Site ID</dt>
        <dd class="col-sm-10">@Model.SiteId</dd>

        <dt class="col-sm-2">Category</dt>
        <dd class="col-sm-10">@(Model.SiteCategory?.Name ?? "None")</dd>

        <dt class="col-sm-2">Max Vehicle Size</dt>
        <dd class="col-sm-10">@Model.MaxVehicleSize</dd>

        <dt class="col-sm-2">Visible To Client</dt>
        <dd class="col-sm-10">@(Model.VisibleToClient ? "Yes" : "No")</dd>
    </dl>

    <h4>Pricing</h4>
    @if (Model.SiteCategory?.PriceRanges != null && Model.SiteCategory.PriceRanges.Any())
    {
        <table class="table table-bordered">
            <thead>
                <tr>
                    <th>Price</th>
                    <th>Start Date</th>
                    <th>End Date</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var range in Model.SiteCategory.PriceRanges.OrderBy(p => p.StartDate))
                {
                    <tr>
                        <td>@range.Price.ToString("C")</td>
                        <td>@range.StartDate.ToShortDateString()</td>
                        <td>@(range.EndDate.HasValue ? range.EndDate.Value.ToShortDateString() : "No end date")</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p>No pricing found for this site category.</p>
    }

    <form asp-action="Delete">
        <input type="hidden" asp-for="SiteId" />
        <input type="submit" value="Delete" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>