@model GroupThreeTrailerParkProject.Models.Site

@{
    ViewData["Title"] = "Site Details";
    var photos = ViewBag.Photos as List<GroupThreeTrailerParkProject.Models.SitePhoto>;
}

<div class="container mt-4">
    <h2 class="mb-4">Site Details</h2>

    <form asp-action="Edit" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <input asp-for="SiteId" type="hidden" />

        <div class="mb-3">
            <label asp-for="SiteId" class="form-label"></label>
            <input asp-for="SiteId" class="form-control" disabled />
        </div>

        <div class="mb-3">
            <label asp-for="SiteCategoryId" class="form-label">Site Category</label>
            <select asp-for="SiteCategoryId" asp-items="ViewBag.SiteCategoryId" class="form-select">
                <option value="">-- Select Category --</option>
            </select>
            <span asp-validation-for="SiteCategoryId" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="MaxVehicleSize" class="form-label"></label>
            <input asp-for="MaxVehicleSize" class="form-control" />
            <span asp-validation-for="MaxVehicleSize" class="text-danger"></span>
        </div>

        <div class="form-check mb-4">
            <input asp-for="VisibleToClient" class="form-check-input" />
            <label asp-for="VisibleToClient" class="form-check-label"></label>
        </div>

        <hr class="my-4" />

        <h4 class="mb-3">Photos</h4>

        <div class="row mb-4">
            @if (photos != null && photos.Any())
            {
                @foreach (var photo in photos)
                {
                    <div class="col-md-3 mb-3">
                        <div class="card shadow-sm">
                            <img src="@photo.PhotoUrl"
                                 class="card-img-top"
                                 alt="Site Photo"
                                 style="height: 180px; object-fit: cover;" />
                        </div>
                    </div>
                }
            }
            else
            {
                <p>No photos have been added for this site yet.</p>
            }
        </div>

        <div class="mb-4">
            <label class="form-label">Add New Photo URL</label>
            <input type="text" name="NewPhotoUrl" class="form-control" placeholder="Enter photo URL here" />
        </div>

        <div class="d-flex gap-2">
            <button type="submit" name="submitButton" value="Apply" class="btn btn-success">Apply</button>
            <button type="submit" name="submitButton" value="Delete" class="btn btn-danger">Delete</button>
            <a asp-action="Index" class="btn btn-secondary">Back</a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}